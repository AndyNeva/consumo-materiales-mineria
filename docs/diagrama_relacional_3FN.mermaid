%% =========================================================================
%% Diagrama Relacional — 3FN (Tercera Forma Normal)
%% Proyecto: Consumo de Materiales - Minería
%% Fuente de verdad: db/01_crear_esquema.py
%% 
%% Contiene las 11 tablas reales de la base de datos SQLite:
%%   1.  usuarios            — usuarios del sistema (autenticación + RBAC)
%%   2.  intentos_login      — control de intentos fallidos y bloqueo
%%   3.  Insumos             — catálogo de materiales con stock
%%   4.  movimientos         — auditoría de cambios de inventario
%%   5.  Zonas               — catálogo de zonas de despacho
%%   6.  Centros_Costo       — catálogo de códigos WBS / centros de costo
%%   7.  Turnos              — catálogo de turnos (Diurno / Nocturno)
%%   8.  Disenos_Mezcla      — catálogo de diseños de mezcla (receta cabecera)
%%   9.  Receta_Detalle      — ingredientes de cada diseño (relación N:M)
%%  10.  Produccion_Diaria   — cabecera de despachos / lotes diarios
%%  11.  Produccion_Insumos  — consumos reales por despacho (relación N:M)
%% =========================================================================

erDiagram

    usuarios {
        INTEGER id PK
        TEXT username UK
        TEXT rol
        TEXT password_hash
    }

    intentos_login {
        TEXT clave PK
        INTEGER intentos
        REAL bloqueado_hasta
    }

    Insumos {
        INTEGER id_insumo PK
        TEXT nombre_insumo UK
        TEXT unidad
        REAL stock_minimo
        REAL stock_maximo
        REAL stock_actual
    }

    movimientos {
        INTEGER id PK
        INTEGER usuario_id FK
        INTEGER id_insumo FK
        REAL cantidad
        TEXT fecha
        TEXT tipo
    }

    Zonas {
        INTEGER id_zona PK
        TEXT nombre_zona UK
    }

    Centros_Costo {
        INTEGER id_cc PK
        TEXT codigo_cc UK
    }

    Turnos {
        INTEGER id_turno PK
        TEXT nombre_turno UK
    }

    Disenos_Mezcla {
        TEXT diseno_mezcla PK
    }

    Receta_Detalle {
        INTEGER id_receta PK
        TEXT diseno_mezcla FK
        INTEGER id_insumo FK
        REAL cantidad_requerida
    }

    Produccion_Diaria {
        INTEGER id_produccion PK
        TEXT fecha
        TEXT lote_numero
        REAL volumen_m3
        TEXT diseno_mezcla FK
        INTEGER id_zona FK
        INTEGER id_cc FK
        REAL arena_humedad_pct
        REAL asentamiento_final_cm
        REAL temperatura_c
        INTEGER id_turno FK
    }

    Produccion_Insumos {
        INTEGER id_produccion PK
        INTEGER id_insumo PK
        REAL cantidad_real
    }

    %% ---- Relaciones de seguridad / auditoría ----
    usuarios ||--o{ movimientos : "registra"
    Insumos  ||--o{ movimientos : "es afectado por"

    %% ---- Relaciones de catálogo → producción ----
    Disenos_Mezcla ||--o{ Produccion_Diaria : "se aplica en"
    Zonas          ||--o{ Produccion_Diaria : "pertenece a"
    Centros_Costo  ||--o{ Produccion_Diaria : "se asigna a"
    Turnos         ||--o{ Produccion_Diaria : "ocurre en"

    %% ---- Relaciones de receta (N:M resuelta) ----
    Disenos_Mezcla ||--o{ Receta_Detalle : "define"
    Insumos        ||--o{ Receta_Detalle : "interviene en"

    %% ---- Relaciones de consumo real (N:M resuelta) ----
    Produccion_Diaria ||--o{ Produccion_Insumos : "consume"
    Insumos           ||--o{ Produccion_Insumos : "es consumido en"

    %% ---- Relación LÓGICA (no FK física) ----
    %% intentos_login NO tiene FK a usuarios. Su PK `clave` tiene el
    %% formato "username@ip" y se asocia lógicamente a usuarios.username.
    %% No se dibuja como arista ER porque no hay constraint de integridad.
    %% Ver auth/login.py: función _clave_intentos(username, ip).
